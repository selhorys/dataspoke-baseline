# Prauto instance-specific configuration — NEVER commit this file.
# Copy to config.local.env and edit before first run.

# Identity (unique per instance)
PRAUTO_WORKER_ID="prauto01"
PRAUTO_GIT_AUTHOR_NAME="prauto01"
PRAUTO_GIT_AUTHOR_EMAIL="prauto01@dataspoke.local"

# Claude Code CLI (tune per instance based on machine capacity)
PRAUTO_CLAUDE_MODEL="sonnet"
PRAUTO_CLAUDE_MAX_TURNS_ANALYSIS=50
PRAUTO_CLAUDE_MAX_TURNS_IMPLEMENTATION=150
PRAUTO_HEARTBEAT_INTERVAL_MINUTES=15

# Integration test fix loop: max Claude fix attempts before giving up (default: 2)
PRAUTO_INTEGRATION_FIX_MAX_RETRIES=2
PRAUTO_CLAUDE_MAX_TURNS_INTEGRATION_FIX=50

# Budget caps (optional — only effective with API billing, ignored on Pro/Max plans)
# PRAUTO_CLAUDE_MAX_BUDGET_ANALYSIS="0.50"
# PRAUTO_CLAUDE_MAX_BUDGET_IMPLEMENTATION="2.00"
# PRAUTO_CLAUDE_MAX_BUDGET_INTEGRATION_FIX="1.00"

# Maximum open issues this worker can hold concurrently (default: 1).
# Counts all open issues assigned to this worker with any prauto: label.
# Higher values let the worker pick up new issues while existing ones are pending.
PRAUTO_OPEN_ISSUE_LIMIT=1

# PR reviewer (GitHub login). Set to the human reviewer.
# Leave empty if the repo owner is an org — org names are not valid reviewers.
PRAUTO_REVIEWER=""

# Secrets (optional — leave empty to use system auth / keyring credentials)
ANTHROPIC_API_KEY=""
GH_TOKEN=""
